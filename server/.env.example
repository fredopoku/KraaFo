# ── Server ──────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Frontend URL (required in production for CORS) ──────────────────
# Set to your deployed domain e.g. https://krafo.app
# In single-server mode (Express serves the React build) you can omit this.
FRONTEND_URL=https://your-domain.com

# ── Database (SQLite) ────────────────────────────────────────────────
# Must be on a persistent volume so data survives redeploys.
# Railway/Render: add a volume mounted at /data → use /data/krafo.db
DB_PATH=./data/krafo.db

# ── File Uploads (logos) ─────────────────────────────────────────────
# Must be on the same persistent volume as the database.
# Railway/Render: /data/uploads
UPLOAD_DIR=./uploads

# ── AI (Anthropic Claude) ────────────────────────────────────────────
# Get your key at https://console.anthropic.com
# Smart Fill and receipt import use this.
# App works without it (falls back to built-in templates).
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Puppeteer / Chrome (PDF generation) ─────────────────────────────
# Leave blank to use Puppeteer's bundled Chromium (works locally).
# On Railway (nixpacks): /nix/store/.../bin/chromium
# On Render: /usr/bin/google-chrome-stable
PUPPETEER_EXECUTABLE_PATH=

# ── Platform Email (SMTP) ────────────────────────────────────────────
# All outgoing emails (invoices, receipts) go through this account.
# For Gmail: enable 2FA then create an App Password at
# myaccount.google.com/apppasswords — use that as SMTP_PASS.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=your@gmail.com

# ── AI — Groq (Smart Fill + document import) ─────────────────────────
# Free key at console.groq.com — no credit card required.
# App works without it (built-in templates + local OCR fallback).
GROQ_API_KEY=your_groq_key_here

# ── AI — Gemini (document import vision fallback) ────────────────────
GEMINI_API_KEY=your_gemini_key_here
